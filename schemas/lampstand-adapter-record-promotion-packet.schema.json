{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/memory-mesh/lampstand-adapter-record-promotion-packet.schema.json",
  "title": "Lampstand Adapter Record Promotion Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "packetId",
    "sourceAuthority",
    "promotionMode",
    "createdAt",
    "scope",
    "records",
    "promotionCandidates",
    "policyDecisionRefs",
    "evidenceRefs"
  ],
  "properties": {
    "schemaVersion": { "const": "memory-mesh.lampstand-adapter-record-promotion-packet.v1" },
    "packetId": { "type": "string", "minLength": 1 },
    "sourceAuthority": { "const": "lampstand.adapter_records" },
    "promotionMode": { "type": "string", "enum": ["review_only", "dry_run", "approved_for_writeback"] },
    "createdAt": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["scopeType", "rootRefs", "memoryMeshTarget"],
      "properties": {
        "scopeType": { "type": "string", "enum": ["repo", "workspace", "workroom", "slash_topic"] },
        "rootRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "memoryMeshTarget": { "type": "string", "minLength": 1 },
        "slashTopicRef": { "type": ["string", "null"] },
        "workroomRef": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/AdapterRecord" }
    },
    "promotionCandidates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/PromotionCandidate" }
    },
    "policyDecisionRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "evidenceRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false,
  "$defs": {
    "AdapterRecord": {
      "type": "object",
      "required": ["recordId", "recordType", "objectKind", "title", "pathRef", "classification", "policyDecision", "source"],
      "properties": {
        "recordId": { "type": "string", "minLength": 1 },
        "recordType": { "type": "string", "minLength": 1 },
        "objectKind": { "type": "string", "enum": ["repo_context", "repo_structure", "security_signal", "memory_candidate", "symbol"] },
        "title": { "type": "string", "minLength": 1 },
        "pathRef": { "type": "string", "minLength": 1 },
        "snippet": { "type": ["string", "null"] },
        "classification": { "type": "string", "enum": ["local_only", "internal", "confidential", "restricted"] },
        "handlingTags": { "type": "array", "items": { "type": "string" } },
        "metadataHash": { "type": ["string", "null"] },
        "contentHash": { "type": ["string", "null"] },
        "policyDecision": {
          "type": "object",
          "required": ["decision", "ruleset"],
          "properties": {
            "decision": { "type": "string", "enum": ["allow", "allow_with_redaction", "review_required", "deny"] },
            "ruleset": { "type": "string" }
          },
          "additionalProperties": true
        },
        "source": {
          "type": "object",
          "required": ["system"],
          "properties": {
            "system": { "type": "string" },
            "repo": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "PromotionCandidate": {
      "type": "object",
      "required": ["candidateId", "sourceRecordId", "candidateType", "recommendedAction", "memoryKind", "content", "confidence"],
      "properties": {
        "candidateId": { "type": "string", "minLength": 1 },
        "sourceRecordId": { "type": "string", "minLength": 1 },
        "candidateType": { "type": "string", "enum": ["repo_onboarding", "security", "procedural", "symbol", "work_episode"] },
        "recommendedAction": { "type": "string", "enum": ["review", "discard", "promote_after_approval"] },
        "memoryKind": { "type": "string", "enum": ["semantic", "episodic", "procedural", "policy", "artifact"] },
        "content": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  }
}
