{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.io/schemas/memory-mesh/slash-topic-memory-profile.schema.json",
  "title": "SlashTopicMemoryProfile",
  "description": "Memory Mesh profile contract for Slash Topic scopes, including explicit Slash Topics/New Hope topology role refs for Lattice query routing.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "memoryProfileRef", "slashTopicScope", "topologyRoles", "recallPolicy", "writebackPolicy", "retention", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "v0.1"},
    "memoryProfileRef": {"type": "string", "minLength": 1},
    "slashTopicScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "membraneId"],
      "properties": {
        "topic": {"type": "string", "minLength": 1},
        "membraneId": {"type": "string", "minLength": 1},
        "channelRef": {"type": "string"}
      }
    },
    "topologyRoles": {
      "type": "object",
      "description": "Explicit role refs preserving Slash Topics as public surface and New Hope as runtime substrate.",
      "additionalProperties": false,
      "required": ["publicSurfaceRef", "runtimeSubstrateRef", "runtimeAliasRef", "compatibilityRef"],
      "properties": {
        "publicSurfaceRef": {"const": "slash-topics-public-surface"},
        "runtimeSubstrateRef": {"const": "new-hope-runtime-substrate"},
        "runtimeAliasRef": {"const": "slash-topics-runtime-alias"},
        "compatibilityRef": {"const": "new-hope-compatibility"}
      }
    },
    "recallPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "sensitivePayloadStorage", "topK"],
      "properties": {
        "scope": {"type": "string", "enum": ["slash-topic-scoped", "session-scoped", "read-only"]},
        "sensitivePayloadStorage": {"type": "string", "enum": ["disallowed", "summarized-only", "allowed-with-redaction"]},
        "topK": {"type": "integer", "minimum": 1, "maximum": 50},
        "scopeOrder": {"type": "array", "items": {"type": "string"}},
        "includeRelations": {"type": "boolean"},
        "includeRawEvents": {"type": "boolean"}
      }
    },
    "writebackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "dryRunMode"],
      "properties": {
        "enabled": {"type": "boolean"},
        "dryRunMode": {"type": "string", "enum": ["no-writeback", "event-refs-only", "summarized-only"]},
        "allowedMemoryClasses": {"type": "array", "items": {"type": "string", "enum": ["interaction", "fact", "preference", "decision", "summary", "scratch"]}}
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "evidenceRequired"],
      "properties": {
        "class": {"type": "string"},
        "evidenceRequired": {"type": "boolean"},
        "ttlDays": {"type": "integer", "minimum": 0}
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "sensitivityThreshold": {"type": "string", "enum": ["public", "internal", "confidential", "restricted"]},
        "redactedFields": {"type": "array", "items": {"type": "string"}}
      }
    },
    "summarization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "maxTokens": {"type": "integer", "minimum": 1},
        "summaryClass": {"type": "string"}
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "promotionTargetScope": {"type": "string"},
        "requiresApproval": {"type": "boolean"}
      }
    },
    "forgetting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "policy": {"type": "string", "enum": ["explicit-delete-only", "ttl-based", "evidence-driven"]}
      }
    },
    "labProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "embeddingModel": {"type": "string"},
        "nlpPipeline": {"type": "string"},
        "multimodalEnabled": {"type": "boolean"},
        "launchLabJobs": {"const": false}
      }
    },
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "queryRoutingPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memoryProfileRef", "memoryEventRef", "publicSurfaceRef", "runtimeSubstrateRef", "runtimeAliasRef", "compatibilityRef"],
          "properties": {
            "memoryProfileRef": {"type": "string", "minLength": 1},
            "memoryEventRef": {"type": "string", "minLength": 1},
            "publicSurfaceRef": {"const": "slash-topics-public-surface"},
            "runtimeSubstrateRef": {"const": "new-hope-runtime-substrate"},
            "runtimeAliasRef": {"const": "slash-topics-runtime-alias"},
            "compatibilityRef": {"const": "new-hope-compatibility"}
          }
        }
      }
    },
    "evidenceRefs": {"type": "array", "items": {"type": "string"}}
  }
}
