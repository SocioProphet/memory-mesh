{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.ai/memory-mesh/ops-history-context-pack.schema.json",
  "title": "OpsHistoryContextPack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contextPackId",
    "specVersion",
    "scope",
    "payloadMode",
    "sourceEventRefs",
    "policyDecisionRefs",
    "retention"
  ],
  "properties": {
    "contextPackId": {
      "type": "string",
      "pattern": "^urn:srcos:context-pack:"
    },
    "specVersion": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workroomRef"],
      "properties": {
        "roomRef": {"type": ["string", "null"]},
        "threadRef": {"type": ["string", "null"]},
        "workroomRef": {"type": "string"},
        "topicRef": {"type": ["string", "null"]},
        "sessionRef": {"type": ["string", "null"]}
      }
    },
    "payloadMode": {
      "type": "string",
      "enum": ["metadata-only", "summary", "ref-only", "redacted"]
    },
    "sourceEventRefs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "artifactRefs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "policyDecisionRefs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "agentRegistryRefs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "redactionRefs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "writebackAllowed"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["ephemeral", "durable", "deny-writeback"]
        },
        "ttlSeconds": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "writebackAllowed": {
          "type": "boolean"
        },
        "promotionRequiresPolicyDecision": {
          "type": "boolean"
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    }
  }
}
