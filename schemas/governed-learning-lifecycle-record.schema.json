{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/memory-mesh/governed-learning-lifecycle-record.schema.json",
  "title": "Memory Mesh Governed Learning Lifecycle Record",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "recordId",
    "createdAt",
    "lifecycleStatus",
    "sourceProposalRef",
    "scope",
    "memoryObject",
    "governance",
    "evidenceRefs",
    "policyDecisionRefs",
    "redaction",
    "writeback"
  ],
  "properties": {
    "apiVersion": { "const": "memory.mesh.governed-learning-lifecycle/v1" },
    "kind": { "const": "GovernedLearningLifecycleRecord" },
    "recordId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "lifecycleStatus": {
      "enum": [
        "accepted-memory",
        "rejected-proposal",
        "revoked-memory",
        "superseded-memory",
        "conflict-reconciliation"
      ]
    },
    "sourceProposalRef": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "required": ["scope", "targetRef", "path"],
      "properties": {
        "scope": { "enum": ["repo", "project", "user", "organization", "enterprise"] },
        "targetRef": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "memoryNamespace": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "memoryObject": {
      "type": "object",
      "required": ["memoryId", "title", "summary", "retention", "sensitivity", "confidence", "representationEnvelope"],
      "properties": {
        "memoryId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "retention": {
          "enum": ["session-only", "repo-durable", "project-durable", "org-durable", "enterprise-durable", "revoked-tombstone"]
        },
        "sensitivity": { "enum": ["public", "internal", "restricted", "sensitive-redacted"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "representationEnvelope": {
          "type": "object",
          "required": [
            "frameType",
            "authoritySource",
            "sourceEpoch",
            "validityWindow",
            "cacheState",
            "dirtyState",
            "revocationStatus",
            "correlationId",
            "evidenceRefs",
            "provenanceRefs",
            "policyContext",
            "writePolicy"
          ],
          "properties": {
            "frameType": {
              "enum": ["accepted-memory", "rejected-proposal", "revoked-memory", "superseded-memory", "conflict-reconciliation"]
            },
            "authoritySource": { "type": "string", "minLength": 1 },
            "sourceEpoch": { "type": "string", "minLength": 1 },
            "validityWindow": {
              "type": "object",
              "required": ["start", "end"],
              "properties": {
                "start": { "type": ["string", "null"], "format": "date-time" },
                "end": { "type": ["string", "null"], "format": "date-time" }
              },
              "additionalProperties": false
            },
            "cacheState": {
              "enum": ["invalid", "shared_valid", "exclusive_authoritative", "modified_uncommitted", "stale", "revoked", "pending_review", "promoted"]
            },
            "dirtyState": { "enum": ["clean", "dirty", "unknown"] },
            "revocationStatus": { "enum": ["active", "revoked", "superseded", "unknown"] },
            "correlationId": { "type": "string", "minLength": 1 },
            "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "provenanceRefs": { "type": "array", "items": { "type": "string" } },
            "policyContext": {
              "type": "object",
              "required": ["policyDecisionRefs", "capabilityRefs"],
              "properties": {
                "policyDecisionRefs": { "type": "array", "items": { "type": "string" } },
                "capabilityRefs": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "writePolicy": {
              "type": "object",
              "required": ["mode", "reviewRequired"],
              "properties": {
                "mode": { "enum": ["no-writeback", "reviewed-writeback", "approved-writeback", "tombstone-writeback"] },
                "reviewRequired": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["reviewRequired", "reviewStatus", "reviewerRefs", "approvalRef", "decisionRef", "decisionRationale"],
      "properties": {
        "reviewRequired": { "type": "boolean" },
        "reviewStatus": { "enum": ["approved", "rejected", "revoked", "superseded", "reconciled"] },
        "reviewerRefs": { "type": "array", "items": { "type": "string" } },
        "approvalRef": { "type": ["string", "null"] },
        "decisionRef": { "type": "string", "minLength": 1 },
        "decisionRationale": { "type": "string", "minLength": 1 },
        "rejectionRef": { "type": ["string", "null"] },
        "revocationRef": { "type": ["string", "null"] },
        "tombstoneRef": { "type": ["string", "null"] },
        "supersedesRefs": { "type": "array", "items": { "type": "string" } },
        "supersededByRef": { "type": ["string", "null"] },
        "conflictsWith": { "type": "array", "items": { "type": "string" } },
        "reconciliationRef": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "policyDecisionRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "redaction": {
      "type": "object",
      "required": ["rawSensitivePayloadStored", "redactionSummary"],
      "properties": {
        "rawSensitivePayloadStored": { "type": "boolean" },
        "redactionSummary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "writeback": {
      "type": "object",
      "required": ["enabled", "performed", "writebackRef"],
      "properties": {
        "enabled": { "type": "boolean" },
        "performed": { "type": "boolean" },
        "writebackRef": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
