# Local M2 Podman defaults
MEMORYD_HOST_PORT=8787
POSTGRES_HOST_PORT=5432
QDRANT_HOST_PORT=6333

MEMORYD_REQUIRE_API_KEY=true
MEMORYD_API_KEY=memorymesh-local-dev

POSTGRES_DB=memorymesh
POSTGRES_USER=memorymesh
POSTGRES_PASSWORD=memorymesh-dev-password
MEMORYMESH_STORE_URI=postgresql://memorymesh:memorymesh-dev-password@postgres:5432/memorymesh

MEMORYMESH_VECTOR_BACKEND=qdrant
QDRANT_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=memorymesh-local
MEMORYMESH_VECTOR_SIZE=256

# Optional backend worker integration
MEM0_BASE_URL=
MEM0_API_KEY=
